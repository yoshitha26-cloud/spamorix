# ============================================
# SPAMORIX BACKEND — ENVIRONMENT VARIABLES
# ============================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env to Git!
# ============================================

# ----- SERVER -----
PORT=5000
NODE_ENV=development

# ----- DATABASE -----
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/spamorix

# MongoDB Atlas (cloud) — replace with your connection string:
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/spamorix?retryWrites=true&w=majority

# ----- JWT AUTHENTICATION -----
# Make this long, random, and secret!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=spamorix_change_this_to_a_very_long_random_string_in_production_2024
JWT_EXPIRES_IN=7d

# ----- CORS -----
# Your frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ----- RATE LIMITING -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ----- LOGGING -----
# Options: error | warn | info | debug
LOG_LEVEL=info

# ----- AI CLASSIFICATION (Optional) -----
# Leave blank to use mock AI (works offline)
# Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
